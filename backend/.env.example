# Database Configuration
# For Render PostgreSQL, use: postgresql://user:password@hostname/dbname
DATABASE_URL=postgresql://user:password@your-render-db.internal/adora

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production

# CORS Origins (comma-separated for production)
# Example: CORS_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]
CORS_ORIGINS=["*"]

# Admin Credentials (Change these in production!)
ADMIN_EMAIL=kingalameen@admin.com
ADMIN_PASSWORD=kingalameenadmin

# Deriv API Configuration
DERIV_APP_ID=1089
DERIV_API_TOKEN=your_deriv_api_token

# Paystack Configuration (if needed)
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# Application Settings
PROJECT_NAME=ABBANDAYA
VERSION=1.0.0
API_V1_STR=/api
